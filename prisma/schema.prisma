// Compusum - Papelería Mayorista Colombiana
// Prisma Schema para Next.js + SQLite

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================
// USUARIOS ADMIN
// =====================
model User {
  id       String  @id @default(cuid())
  name     String
  email    String? @unique
  phone    String? @unique
  password String // Hash bcrypt
  role     String  @default("CUSTOMER") // admin, editor, AGENT, CUSTOMER
  isActive Boolean @default(true)

  assignedAgentId String?
  assignedAgent   User?   @relation("AgentCustomers", fields: [assignedAgentId], references: [id])
  customers       User[]  @relation("AgentCustomers")
  managedOrders   Order[] @relation("AgentOrders")
  orders          Order[] @relation("CustomerOrders")

  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sessions  Session[]
}

// =====================
// SESIONES
// =====================
model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

// =====================
// CATEGORÍAS
// =====================
model Category {
  id              String     @id @default(cuid())
  name            String
  slug            String     @unique
  description     String?
  image           String?
  icon            String? // Emoji o clase CSS
  parentId        String?
  parent          Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Cascade)
  children        Category[] @relation("CategoryTree")
  sortOrder       Int        @default(0)
  isActive        Boolean    @default(true)
  catalogMode     Boolean    @default(false)
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  products        Product[]
}

// =====================
// MARCAS
// =====================
model Brand {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  logo        String?
  website     String?
  isActive    Boolean   @default(true)
  catalogMode Boolean   @default(false)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

// =====================
// TEMPORADAS
// =====================
model Season {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  description String?
  image       String?
  startDate   DateTime?
  endDate     DateTime?
  colorHex    String?         @default("#E89A00")
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  products    ProductSeason[]
}

// =====================
// PRODUCTOS
// =====================
model Product {
  id               String          @id @default(cuid())
  name             String
  slug             String          @unique
  sku              String?         @unique
  description      String?
  shortDescription String?
  categoryId       String
  category         Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  brandId          String?
  brand            Brand?          @relation(fields: [brandId], references: [id], onDelete: SetNull)
  price            Float?
  wholesalePrice   Float?
  minWholesaleQty  Int             @default(1)
  stockStatus      String          @default("disponible") // disponible, agotado, por_pedido
  isFeatured       Boolean         @default(false)
  isNew            Boolean         @default(false)
  isActive         Boolean         @default(true)
  catalogMode      Boolean         @default(false)
  tags             String?
  sortOrder        Int             @default(0)
  viewsCount       Int             @default(0)
  metaTitle        String?
  metaDescription  String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  images           ProductImage[]
  seasons          ProductSeason[]
  cartItems        CartItem[]
}

// =====================
// IMÁGENES DE PRODUCTOS
// =====================
model ProductImage {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  imagePath     String
  thumbnailPath String?
  altText       String?
  isPrimary     Boolean  @default(false)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
}

// =====================
// TABLA PIVOTE PRODUCTO-TEMPORADA
// =====================
model ProductSeason {
  productId String
  seasonId  String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  season    Season  @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@id([productId, seasonId])
}

// =====================
// BANNERS
// =====================
model Banner {
  id           String    @id @default(cuid())
  title        String
  subtitle     String?
  imageDesktop String
  imageMobile  String?
  linkUrl      String?
  linkText     String    @default("Ver más")
  position     String    @default("hero") // hero, promo, category, brand
  isActive     Boolean   @default(true)
  sortOrder    Int       @default(0)
  startsAt     DateTime?
  endsAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// =====================
// MENSAJES DE CONTACTO
// =====================
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  city      String?
  company   String?
  message   String
  type      String   @default("consulta") // consulta, cotizacion, queja, otro
  isRead    Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())
}

// =====================
// DEPARTAMENTOS (Logística)
// =====================
model Department {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  isActive  Boolean  @default(true)
  cities    City[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =====================
// CIUDADES
// =====================
model City {
  id              String         @id @default(cuid())
  name            String
  slug            String         @unique
  departmentId    String
  department      Department     @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  shippingRouteId String?
  shippingRoute   ShippingRoute? @relation(fields: [shippingRouteId], references: [id], onDelete: SetNull)
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  carts           Cart[]
  orders          Order[]

  @@index([departmentId])
  @@index([shippingRouteId])
}

// =====================
// RUTAS DE ENVÍO
// =====================
model ShippingRoute {
  id               String    @id @default(cuid())
  name             String
  estimatedDaysMin Int
  estimatedDaysMax Int
  shippingCompany  String?
  notes            String?
  isActive         Boolean   @default(true)
  capacity         Int?
  cutOffTime       DateTime?
  departureDate    DateTime?
  sortOrder        Int       @default(0)
  cities           City[]
  orders           Order[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// =====================
// CARRITO DE COMPRAS
// =====================
model Cart {
  id              String     @id @default(cuid())
  uuid            String     @unique @default(uuid())
  sessionId       String?    // Session ID del navegador para usuarios invitados
  userId          String?    // User ID para usuarios logueados
  customerName    String?
  customerEmail   String?
  customerPhone   String?
  customerCompany String?
  cityId          String?
  city            City?      @relation(fields: [cityId], references: [id], onDelete: SetNull)
  notes           String?
  status          String     @default("activo") // activo, compartido, convertido, expirado
  isActive        Boolean    @default(true)
  subtotal        Float      @default(0)
  items           CartItem[]
  orders          Order[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  expiresAt       DateTime?

  @@unique([sessionId, status]) // Garantiza un único carrito activo por sesión
  @@index([uuid])
  @@index([status])
  @@index([sessionId])
  @@index([userId])
  @@index([customerEmail])
}

// =====================
// ITEMS DEL CARRITO
// =====================
model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  unitPrice Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
  @@index([cartId])
}

// =====================
// PEDIDOS
// =====================
model Order {
  id          String @id @default(cuid())
  orderNumber String @unique
  cartId      String
  cart        Cart   @relation(fields: [cartId], references: [id])

  customerId String?
  customer   User?   @relation("CustomerOrders", fields: [customerId], references: [id])
  agentId    String?
  agent      User?   @relation("AgentOrders", fields: [agentId], references: [id])

  sessionId       String? // Session ID para rastreo de usuarios invitados
  customerName    String?
  customerEmail   String?
  customerPhone   String?
  customerCompany String?
  cityId          String?
  city            City?                @relation(fields: [cityId], references: [id])
  routeId         String?
  route           ShippingRoute?       @relation(fields: [routeId], references: [id])
  notes           String?
  subtotal        Float
  status          String               @default("solicitado") // solicitado, compartido, recibido
  webhookSent     Boolean              @default(false)
  webhookResponse String?
  sentVia         String? // whatsapp, email, webhook
  items           OrderItem[]
  statusHistory   OrderStatusHistory[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@unique([sessionId, status]) // Garantiza un único pedido activo por sesión para usuarios invitados
  @@unique([customerId, status]) // Garantiza un único pedido activo por usuario logueado
  @@index([status])
  @@index([orderNumber])
  @@index([cartId])
  @@index([sessionId])
  @@index([customerId])
  @@index([cityId])
}

// =====================
// ITEMS DEL PEDIDO (snapshot)
// =====================
model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  productName String
  productSku  String?
  quantity    Int
  unitPrice   Float?
  createdAt   DateTime @default(now())

  @@index([orderId])
}

// =====================
// HISTORIAL DE ESTADOS DEL PEDIDO
// =====================
model OrderStatusHistory {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus String?
  toStatus   String
  changedBy  String?
  note       String?
  createdAt  DateTime @default(now())

  @@index([orderId])
}

// =====================
// CONFIGURACIONES DEL SITIO
// =====================
model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String?
  type      String   @default("text") // text, number, boolean, json, image
  group     String   @default("general") // general, contact, social, shipping, seo
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
